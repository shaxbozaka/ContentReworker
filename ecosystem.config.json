{
  "name": "content-reworker",
  "script": "dist/index.js",
  "instances": 1,
  "exec_mode": "cluster",
  "env": {
    "NODE_ENV": "production",
    "PORT": 5000
  },
  "env_file": ".env.production",
  "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
  "error_file": "logs/error.log",
  "out_file": "logs/out.log",
  "log_file": "logs/combined.log",
  "time": true,
  "autorestart": true,
  "max_restarts": 10,
  "min_uptime": "10s",
  "max_memory_restart": "1G",
  "watch": false,
  "ignore_watch": [
    "node_modules",
    "logs",
    "dist/public"
  ]
}